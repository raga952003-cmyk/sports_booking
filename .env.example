# TCS PlaySmart - Environment Variables Template

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Your Supabase Project URL
SUPABASE_URL=https://kmcecytuzizhiokvwnlq.supabase.co

# IMPORTANT: Use SERVICE ROLE KEY for backend, NOT the publishable key!
# This is the 'service_role' key from API settings (starts with eyJ...)
SUPABASE_KEY=your_service_role_key_here

# ============================================
# DATABASE DIRECT CONNECTION (Optional)
# ============================================
# For running migrations or direct database access
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.kmcecytuzizhiokvwnlq.supabase.co:5432/postgres

# ============================================
# FALLBACK MODE
# ============================================
# If SUPABASE_URL or SUPABASE_KEY is empty, the app will use SQLite as fallback
# SQLite database file: playsmart_sandbox.db
